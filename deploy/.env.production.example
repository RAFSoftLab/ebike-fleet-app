# ---------------------------------------------------------------------------
# Production environment for the eBike Fleet API.
# Copy this to the repo root as `.env` and fill in real secrets:
#     cp deploy/.env.production.example .env
# This file is read by systemd (EnvironmentFile) and by deploy.sh for migrations.
# Keep it out of git (.env is already gitignored).
# ---------------------------------------------------------------------------

# Postgres connection. Must match the DB user/password/name created in deploy.sh.
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg2://ebike:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/ebike_db

# JWT signing. MUST be a long random string. Generate one with:
#     openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32
JWT_ALGORITHM=HS256

# Comma-separated list of emails that get admin privileges.
admin_emails_csv=admin@admin.com
